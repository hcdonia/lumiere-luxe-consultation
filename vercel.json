{
  "name": "lumiere-luxe-consultation",
  "buildCommand": "",
  "outputDirectory": "public",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ],
  "crons": [
    { "path": "/api/send-appointment-reminders", "schedule": "0 2 * * *" },
    { "path": "/api/send-appointment-reminders", "schedule": "0 3 * * *" },
    { "path": "/api/send-appointment-reminders", "schedule": "0 15 * * *" },
    { "path": "/api/send-appointment-reminders", "schedule": "0 16 * * *" }
  ]
}
